# Copy to .env and fill in values. Used by the app; Docker Compose loads this via `env_file: .env`.
#
# --- Docker Compose (see docker-compose.yml) ---
# JDBC host must be the PostgreSQL *service* name (postgres), not localhost, e.g.:
# DB_URL=jdbc:postgresql://postgres:5432/examinai
# (database name `examinai` matches application-dev and Docker postgres service.)
# Ollama: use the compose service name (ollama), e.g.:
# OLLAMA_BASE_URL=http://ollama:11434
# (application.yml also defaults to http://ollama:11434 if unset; avoid empty
#  OLLAMA_BASE_URL in .env, or set it explicitly to the URL above for Docker runs.)

DB_URL=
DB_USERNAME=
DB_PASSWORD=
GITHUB_TOKEN=
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
OLLAMA_BASE_URL=
